{
  "name": "abc-learning-center-backend",
  "version": "1.0.0",
  "private": true,
  "description": "ABC Learning Center Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:all": "npx concurrently \"npm run dev\" \"npm --prefix client run dev\"",
    "start:all": "npx concurrently \"npm run dev\" \"npm --prefix client run dev\"",
    "build": "tsc && npm --prefix client install && npm --prefix client run build",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "serverless-http": "^3.0.0",
    "@supabase/supabase-js": "^2.39.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2"
  }
}
